[help]
  autocorrect = 1

[status]
  submodule = 1

[instaweb]
    httpd = webrick
    port = 1234

[branch]
	autosetuprebase = always

[credential]
  helper = osxkeychain

[merge]
  tool = vimdiff
  conflictstyle = diff3

[difftool "sourcetree"]
	cmd = opendiff \"$LOCAL\" \"$REMOTE\"
	path = 
[mergetool "sourcetree"]
	cmd = /Users/berryp/Library/Application Support/SourceTree/SourceTree 1.8.0.2/SourceTree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
	trustExitCode = true
[diff]
	tool = vimdiff
[difftool]
	prompt = false
