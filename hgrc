[ui]
username = Berry Phillips <berryphillips@gmail.com>

[pager]
pager = LESS='FSRX' less

[extensions]
extdiff =
# Enable the ascii graph log
hgext.graphlog =
# enable color output
color =
# hmm
hgext.highlight =
# Show progress bar on long operations
progress =
# Pipe long output to less.
pager =
# hgk=/usr/local/bin/hgk
purge =
prompt = ~/bin/hgprompt.py
rebase =
mq =

[extdiff]
cmd.interdiff = hg-interdiff
cmd.opendiff = opendiff-w

[merge-tools]
filemerge.executable = opendiff-w
filemerge.args = $local $other -ancestor $base -merge $output
