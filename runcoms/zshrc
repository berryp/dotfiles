# Source Prezto.
if [[ -s "${ZDOTDIR:-$HOME}/.zprezto/init.zsh" ]]; then
  source "${ZDOTDIR:-$HOME}/.zprezto/init.zsh"
fi

# Customize to your needs...

export LC_ALL='en_US.UTF-8'
export LANG='en_US.UTF-8'

export EDITOR='vim'

HIST_STAMPS='yyyy-mm-dd'
export HISTTIMEFORMAT='-i '

alias gist='gist -c -p -s'
alias grep='grep --exclude="*.egg/" --exclude="*.min.js"'
alias agrep="grep --color=auto -nr -A 2 -B 2"

alias docker-clean='docker rm `docker ps --no-trunc -aq` && docker images -q --filter "dangling=true" | xargs docker rmi'
alias asjson='python3 -m json.tool'
alias server='python3 -m http.server'

alias gssh='gcloud compute ssh'

export PATH=$HOME/bin:$PATH
export GOPATH=$HOME/go
export PATH=/usr/local/go/bin:$GOPATH/bin:$PATH

# FZF
if [ -f ~/.fzf.zsh ]; then
  source ~/.fzf.zsh
  if hash ag 2>/dev/null; then
    export FZF_DEFAULT_COMMAND='ag --nocolor --ignore node_modules -g ""'
  fi
fi

# Kubernetes prompt
if [ -f $HOME/.zsh-kubectl-prompt/kubectl.zsh ]; then
  autoload -U colors; colors
  source $HOME/.zsh-kubectl-prompt/kubectl.zsh
  RPROMPT='%{$fg[blue]%}($ZSH_KUBECTL_PROMPT)%{$reset_color%}'
fi

# Google Cloud SDK
if [ -f '/opt/google-cloud-sdk/path.zsh.inc' ]; then . '/opt/google-cloud-sdk/path.zsh.inc'; fi
if [ -f '/opt/google-cloud-sdk/completion.zsh.inc' ]; then . '/opt/google-cloud-sdk/completion.zsh.inc'; fi

# kubectl
if hash kubectl 2>/dev/null; then alias kc=kubectl; fi
if hash kubectx 2>/dev/null; then alias kc=kubectx; fi
if hash kubens 2>/dev/null; then alias kc=kubens; fi

# jenv
# if [ -x /usr/local/bin/jenv ]; then
#   export PATH="$HOME/.jenv/bin:$PATH"
#   eval "$(jenv init -)"
#   export JAVA_HOME=$(jenv javahome);
# fi

# pyenv
if [ -f $HOME/.pyenv/bin/pyenv ]; then
  export PATH="$HOME/.pyenv/bin:$PATH"
  eval "$(pyenv init -)"
  eval "$(pyenv virtualenv-init -)"
fi

# Android SDK
if [ -d $HOME/Library/Android/sdk ]; then
  export PATH=$HOME/Library/Android/sdk/tools/bin:$PATH
  export ANDROID_SDK_ROOT=$HOME/Library/Android/sdk
fi


# For compilers to find zlib:
export LDFLAGS="${LDFLAGS} -L/usr/local/opt/zlib/lib"
export CPPFLAGS="${CPPFLAGS} -I/usr/local/opt/zlib/include"

# For pkg-config to find zlib:
export PKG_CONFIG_PATH="${PKG_CONFIG_PATH} /usr/local/opt/zlib/lib/pkgconfig"

# Base16 Shell
BASE16_SHELL="$HOME/.config/base16-shell/"
[ -n "$PS1" ] && \
    [ -s "$BASE16_SHELL/profile_helper.sh" ] && \
        eval "$("$BASE16_SHELL/profile_helper.sh")"


export PATH="$PATH:$HOME/flutter/bin"

