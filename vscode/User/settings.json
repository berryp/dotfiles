{
    "editor.fontSize": 14,
    "workbench.iconTheme": "vscode-icons",
    "vsicons.dontShowNewVersionMessage": true,
    "gitlens.advanced.messages": {
        "suppressCommitHasNoPreviousCommitWarning": false,
        "suppressCommitNotFoundWarning": false,
        "suppressFileNotUnderSourceControlWarning": false,
        "suppressGitVersionWarning": false,
        "suppressLineUncommittedWarning": false,
        "suppressNoRepositoryWarning": false,
        "suppressResultsExplorerNotice": false,
        "suppressShowKeyBindingsNotice": true,
        "suppressUpdateNotice": true,
        "suppressWelcomeNotice": false
    },
    "python.linting.flake8Path": "~/.pyenv/shims/flake8",
    "python.linting.flake8Enabled": true,
    "python.linting.mypyPath": "~/.pyenv/shims/mypy",
    "python.formatting.yapfPath": "~/.pyenv/shims/yapf",
    "workbench.startupEditor": "newUntitledFile",
    "python.linting.flake8Args": [
        "--ignore=E128,E402"
    ],
    "python.linting.pylintEnabled": false,
    "python.formatting.provider": "black",
    "editor.formatOnSave": true,
    "python.formatting.yapfArgs": [
        "--style=pep8"
    ],
    "files.associations": {
        "Dockerfile.*": "dockerfile",
        "Dockerfile-*": "dockerfile",
        "zshrc": "shellscript",
        "zpreztorc": "shellscript",
        "gitconfig": "properties"
    },
    "gitlens.keymap": "alternate",
    "nasc-touchbar.toggleSidebar": true,
    "nasc-touchbar.toggleWhiteSpace": true,
    "nasc-touchbar.selectNext": false,
    "editor.renderWhitespace": "none",
    "gitlens.historyExplorer.enabled": true,
    "editor.minimap.enabled": false,
    "telemetry.enableCrashReporter": false,
    "gitlens.gitExplorer.files.layout": "auto",
    "git.autofetch": true,
    "latex-workshop.latex.autoBuild.cleanAndRetry.enabled": false,
    "gitlens.views.repositories.files.layout": "auto",
    "gitlens.views.fileHistory.enabled": true,
    "gitlens.views.lineHistory.enabled": true,
    "files.exclude": {
        "**/.classpath": true,
        "**/.project": true,
        "**/.settings": true,
        "**/.factorypath": true
    }
}